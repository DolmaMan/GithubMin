<Window x:Class="GithubMinClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GithubMinClient.ViewModels"
        Title="Мини-гит" Height="760" Width="1180" MinHeight="640" MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,4,8,4" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="110" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B3261E" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <DataTemplate DataType="{x:Type vm:LoginPageViewModel}">
            <Grid Background="#F4F7FB">
                <Border Width="420" Padding="34" Background="White" CornerRadius="18"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Мини-гит" FontSize="30" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock Text="Вход в систему контроля снапшотов" Foreground="#5F6B7A" Margin="0,0,0,24" />

                        <TextBlock Text="Логин или электронная почта" />
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Войти" Command="{Binding LoginCommand}" />
                            <Button Content="Регистрация" Command="{Binding OpenRegisterCommand}" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterPageViewModel}">
            <Grid Background="#F4F7FB">
                <Border Width="460" Padding="34" Background="White" CornerRadius="18"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Регистрация" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

                        <TextBlock Text="Имя пользователя" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Электронная почта" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Создать" Command="{Binding RegisterCommand}" />
                            <Button Content="Назад" Command="{Binding OpenLoginCommand}" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectsPageViewModel}">
            <Grid Background="#F7F8FA" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Проекты" FontSize="28" FontWeight="Bold" DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Content="Обновить" Command="{Binding RefreshCommand}" />
                        <Button Content="Выйти" Command="{Binding LogoutCommand}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Мои проекты" Grid.Row="0" Padding="10">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="0,10,0,0">
                                    <Button Content="Открыть" Command="{Binding OpenSelectedProjectCommand}" />
                                    <Button Content="Привязать папку" Command="{Binding AttachDirectoryToSelectedProjectCommand}" />
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding MyProjects}" SelectedItem="{Binding SelectedMyProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="140" />
                                        <DataGridTextColumn Header="Вид" Binding="{Binding VisibilityText}" Width="90" />
                                        <DataGridTextColumn Header="Ветки" Binding="{Binding BranchCount}" Width="60" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="70" />
                                        <DataGridTextColumn Header="Локальная папка" Binding="{Binding LocalStatus}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Header="Публичные проекты" Grid.Row="2" Padding="10">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBox Width="300" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Поиск" Command="{Binding SearchCommand}" />
                                    <Button Content="Открыть" Command="{Binding OpenSelectedProjectCommand}" />
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding PublicProjects}" SelectedItem="{Binding SelectedPublicProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="140" />
                                        <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerUsername}" Width="120" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="70" />
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>

                    <Border Grid.Column="2" Padding="18" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Создать проект" Style="{StaticResource SectionTitle}" />

                            <TextBlock Text="Название" />
                            <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Описание" />
                            <TextBox Text="{Binding NewProjectDescription, UpdateSourceTrigger=PropertyChanged}" Height="78" AcceptsReturn="True" TextWrapping="Wrap" />

                            <TextBlock Text="Видимость" />
                            <ComboBox ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding NewProjectVisibilityOption}" DisplayMemberPath="Text" />

                            <TextBlock Text="Рабочая директория" />
                            <TextBox Text="{Binding NewProjectDirectory}" IsReadOnly="True" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Выбрать папку" Command="{Binding ChooseNewProjectDirectoryCommand}" />
                                <Button Content="Создать" Command="{Binding CreateProjectCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="2" Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectDetailsPageViewModel}">
            <Grid Background="#F7F8FA" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold" />
                        <TextBlock Text="{Binding Project.Description}" Foreground="#5F6B7A" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Content="Обновить" Command="{Binding ReloadCommand}" />
                        <Button Content="Назад" Command="{Binding BackCommand}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="16" Background="White" CornerRadius="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Рабочая директория" Style="{StaticResource SectionTitle}" />
                                    <TextBox Text="{Binding WorkingDirectory}" IsReadOnly="True" />
                                    <Button Content="Изменить директорию" Command="{Binding ChangeDirectoryCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" Background="White" CornerRadius="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Ветки" Style="{StaticResource SectionTitle}" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" DisplayMemberPath="Name" />
                                    <Button Content="Переключить ветку" Command="{Binding SwitchBranchCommand}" HorizontalAlignment="Left" />

                                    <Separator Margin="0,14,0,14" />
                                    <TextBlock Text="Новая ветка" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Стартовый коммит" />
                                    <ComboBox ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedStartCommit}" DisplayMemberPath="Message" />
                                    <Button Content="Создать ветку" Command="{Binding CreateBranchCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" Background="White" CornerRadius="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Новый коммит" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="При коммите клиент сам архивирует рабочую директорию." TextWrapping="Wrap" Foreground="#5F6B7A" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" />
                                    <Button Content="Создать коммит" Command="{Binding CreateCommitCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" Background="White" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="Слияние" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Исходная ветка" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedSourceBranch}" DisplayMemberPath="Name" />
                                    <TextBlock Text="Целевая ветка" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedTargetBranch}" DisplayMemberPath="Name" />
                                    <TextBlock Text="Сообщение" />
                                    <TextBox Text="{Binding MergeMessage, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Выполнить слияние" Command="{Binding MergeCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <GroupBox Grid.Column="2" Header="Снапшоты / коммиты" Padding="10">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="0,10,0,0">
                                <Button Content="Скачать снапшот" Command="{Binding DownloadCommitCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="125" />
                                    <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*" />
                                    <DataGridTextColumn Header="Ветка" Binding="{Binding BranchName}" Width="100" />
                                    <DataGridTextColumn Header="Автор" Binding="{Binding AuthorUsername}" Width="100" />
                                    <DataGridTextColumn Header="Идентификатор коммита" Binding="{Binding Id}" Width="210" />
                                    <DataGridTextColumn Header="Родитель" Binding="{Binding ParentCommitId}" Width="210" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>
                </Grid>

                <TextBlock Grid.Row="2" Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentPage}" />
</Window>
