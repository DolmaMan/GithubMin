<Window x:Class="GithubMinClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GithubMinClient.ViewModels"
        Title="GithubMin" Height="820" Width="1280" MinHeight="700" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="#17181C"
        FontFamily="Segoe UI Semibold"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="WindowBrush" Color="#17181C" />
        <SolidColorBrush x:Key="PageBrush" Color="#1C1E23" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#24272D" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#2B2F36" />
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#373046" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8A78BB" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#AA9CD4" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#665A8A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2F4F8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#BCC2CF" />
        <SolidColorBrush x:Key="StatusBrush" Color="#F1B3CB" />
        <SolidColorBrush x:Key="LineBrush" Color="#434852" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E2025" />

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1B20" Offset="0" />
            <GradientStop Color="#272431" Offset="0.58" />
            <GradientStop Color="#1D1E24" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Window">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="22" />
        </Style>

        <Style x:Key="PageHeading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="2"
                                Background="{StaticResource AccentBorderBrush}"
                                CornerRadius="6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}" Background="Transparent">
                <Border Margin="2,0" Background="#23262D" CornerRadius="6" />
                <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}" Background="Transparent">
                <Border Margin="0,2" Background="#23262D" CornerRadius="6" />
                <Track x:Name="PART_Track" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,16" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,16" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#554A74" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,6,12,6" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="2"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7667A1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#21242B" />
            <Setter Property="BorderBrush" Value="#555A66" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#2A2D34" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313541" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#554A74" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#323641" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="18">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,14" />
                                <ContentPresenter />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource StatusBrush}" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="BusyBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="IsIndeterminate" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#302644" />
        </Style>

        <DataTemplate DataType="{x:Type vm:LoginPageViewModel}">
            <Grid Background="{StaticResource HeroBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="72,56,36,56" VerticalAlignment="Center">
                    <Border Width="104" Height="104" CornerRadius="52" Background="#3A3450" HorizontalAlignment="Left">
                        <TextBlock Text="GM" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="GithubMin" Style="{StaticResource PageHeading}" FontSize="46" Margin="0,28,0,12" />
                    <TextBlock Style="{StaticResource MutedText}"
                               FontSize="18"
                               Text="Локальная система контроля снапшотов с ветками, коммитами и слиянием в едином desktop-интерфейсе." />
                    <Border Margin="0,32,0,0" Padding="22" CornerRadius="18" Background="#22242A" BorderBrush="#45495A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Что доступно" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Style="{StaticResource MutedText}" Text="Коммиты снимков состояния, управление ветками, merge с конфликтами, публичные и приватные репозитории." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" MaxWidth="470" Margin="28,48,44,48" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxHeight="680">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,22,0">
                    <StackPanel>
                        <TextBlock Text="Вход" Style="{StaticResource PageHeading}" FontSize="32" Margin="0,0,0,6" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,22"
                                   Text="Войдите по логину или email, чтобы открыть свои репозитории и продолжить работу." />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Логин или электронная почта" />
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Войти" Command="{Binding LoginCommand}" />
                            <Button Content="Регистрация" Style="{StaticResource GhostButton}" Command="{Binding OpenRegisterCommand}" />
                        </WrapPanel>

                        <ProgressBar Style="{StaticResource BusyBarStyle}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterPageViewModel}">
            <Grid Background="{StaticResource HeroBrush}">
                <Border Style="{StaticResource CardBorder}" MaxWidth="520" Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="720">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,22,0">
                    <StackPanel>
                        <TextBlock Text="Регистрация" Style="{StaticResource PageHeading}" FontSize="32" Margin="0,0,0,6" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,22"
                                   Text="Создайте аккаунт для работы с приватными и публичными репозиториями." />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Имя пользователя" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Электронная почта" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Создать" Command="{Binding RegisterCommand}" />
                            <Button Content="Назад" Style="{StaticResource GhostButton}" Command="{Binding OpenLoginCommand}" />
                        </WrapPanel>

                        <ProgressBar Style="{StaticResource BusyBarStyle}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectsPageViewModel}">
            <Grid Background="Transparent" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Репозитории" Style="{StaticResource PageHeading}" FontSize="32" />
                            <TextBlock Style="{StaticResource MutedText}" Text="Управляйте своими проектами, находите публичные репозитории и просматривайте пользователей." />
                        </StackPanel>
                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Обновить" Command="{Binding RefreshCommand}" />
                            <Button Content="Выйти" Style="{StaticResource GhostButton}" Command="{Binding LogoutCommand}" />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Мои репозитории" Grid.Row="0">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                    <Button Content="Открыть" Command="{Binding OpenSelectedProjectCommand}" />
                                    <Button Content="Привязать папку" Style="{StaticResource GhostButton}" Command="{Binding AttachDirectoryToSelectedProjectCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding MyProjects}" SelectedItem="{Binding SelectedMyProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150" />
                                        <DataGridTextColumn Header="Вид" Binding="{Binding VisibilityText}" Width="95" />
                                        <DataGridTextColumn Header="Ветки" Binding="{Binding BranchCount}" Width="60" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="72" />
                                        <DataGridTextColumn Header="Локальная папка" Binding="{Binding LocalStatus}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Header="Публичные репозитории" Grid.Row="2">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBox Width="320" Margin="0,0,10,0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Поиск" Command="{Binding SearchCommand}" />
                                    <Button Content="Открыть" Style="{StaticResource GhostButton}" Command="{Binding OpenSelectedProjectCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding PublicProjects}" SelectedItem="{Binding SelectedPublicProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150" />
                                        <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerUsername}" Width="130" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="72" />
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                        <StackPanel>
                                <TextBlock Text="Создать репозиторий" Style="{StaticResource SectionTitle}" />
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,12"
                                           Text="Создайте новый репозиторий и сразу привяжите к нему локальную рабочую директорию." />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Название" />
                                <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Описание" />
                                <TextBox Text="{Binding NewProjectDescription, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Видимость" />
                                <ComboBox ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding NewProjectVisibilityOption}" DisplayMemberPath="Text" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Рабочая директория" />
                                <TextBox Text="{Binding NewProjectDirectory}" IsReadOnly="True" />
                                <WrapPanel>
                                    <Button Content="Выбрать папку" Command="{Binding ChooseNewProjectDirectoryCommand}" />
                                    <Button Content="Создать" Command="{Binding CreateProjectCommand}" />
                                </WrapPanel>

                                <Separator Margin="0,18,0,18" Background="{StaticResource LineBrush}" />

                                <TextBlock Text="Поиск пользователей" Style="{StaticResource SectionTitle}" />
                                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,12"
                                           Text="Найдите пользователя по имени и откройте список его публичных репозиториев." />
                                <TextBox Text="{Binding UserSearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel>
                                    <Button Content="Найти" Command="{Binding SearchUsersCommand}" />
                                    <Button Content="Публичные репо" Style="{StaticResource GhostButton}" Command="{Binding LoadSelectedUserProjectsCommand}" />
                                </WrapPanel>

                                <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="150" MaxHeight="220">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Пользователь" Binding="{Binding Username}" Width="*" />
                                        <DataGridTextColumn Header="Зарегистрирован" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="125" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Публичные репозитории пользователя" Style="{StaticResource SectionTitle}" Margin="0,18,0,10" />
                                <Button Content="Открыть выбранный" Command="{Binding OpenSelectedProjectCommand}" HorizontalAlignment="Left" />
                                <DataGrid ItemsSource="{Binding SelectedUserProjects}" SelectedItem="{Binding SelectedUserProject}" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="170">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="130" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="72" />
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <ProgressBar Style="{StaticResource BusyBarStyle}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectDetailsPageViewModel}">
            <Grid Background="Transparent" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource PageHeading}" FontSize="30" />
                            <TextBlock Style="{StaticResource MutedText}" Text="{Binding Project.Description}" />
                        </StackPanel>
                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Обновить" Command="{Binding ReloadCommand}" />
                            <Button Content="Назад" Style="{StaticResource GhostButton}" Command="{Binding BackCommand}" />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.08*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Рабочая директория" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8"
                                               Text="Коммиты и восстановление снапшотов работают с локальной привязанной папкой." />
                                    <TextBox Text="{Binding WorkingDirectory}" IsReadOnly="True" />
                                    <Button Content="Изменить директорию" Command="{Binding ChangeDirectoryCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Ветки" Style="{StaticResource SectionTitle}" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" DisplayMemberPath="Name" />
                                    <Button Content="Переключить ветку" Command="{Binding SwitchBranchCommand}" HorizontalAlignment="Left" />

                                    <Separator Margin="0,16,0,16" Background="{StaticResource LineBrush}" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Новая ветка" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Стартовый коммит" />
                                    <ComboBox ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedStartCommit}" DisplayMemberPath="Message" />
                                    <Button Content="Создать ветку" Command="{Binding CreateBranchCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Новый коммит" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8"
                                               Text="Клиент архивирует рабочую директорию, исключая служебные каталоги, и отправляет snapshot на сервер." />
                                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Height="76" AcceptsReturn="True" TextWrapping="Wrap" />
                                    <Button Content="Создать коммит" Command="{Binding CreateCommitCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Слияние" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8"
                                               Text="Выберите исходную и целевую ветки. При конфликте система вернет список конфликтующих файлов." />
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Исходная ветка" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedSourceBranch}" DisplayMemberPath="Name" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Целевая ветка" />
                                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedTargetBranch}" DisplayMemberPath="Name" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Сообщение" />
                                    <TextBox Text="{Binding MergeMessage, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Выполнить слияние" Command="{Binding MergeCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <GroupBox Grid.Column="2" Header="Снапшоты и коммиты">
                        <DockPanel>
                            <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                <Button Content="Скачать снапшот" Command="{Binding DownloadCommitCommand}" />
                                <Button Content="Восстановить снапшот" Style="{StaticResource GhostButton}" Command="{Binding RestoreCommitCommand}" />
                            </WrapPanel>
                            <DataGrid ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130" />
                                    <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*" />
                                    <DataGridTextColumn Header="Ветка" Binding="{Binding BranchName}" Width="104" />
                                    <DataGridTextColumn Header="Автор" Binding="{Binding AuthorUsername}" Width="110" />
                                    <DataGridTextColumn Header="Коммит" Binding="{Binding Id}" Width="210" />
                                    <DataGridTextColumn Header="Родитель" Binding="{Binding ParentCommitId}" Width="210" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <ProgressBar Style="{StaticResource BusyBarStyle}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentPage}" />
</Window>
