<Window x:Class="GithubMinClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GithubMinClient.ViewModels"
        Title="GithubMin" Height="820" Width="1280" MinHeight="700" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="#17181C"
        FontFamily="Segoe UI Semibold"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="WindowBrush" Color="#17181C" />
        <SolidColorBrush x:Key="PageBrush" Color="#1C1E23" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#24272D" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#2B2F36" />
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#373046" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8A78BB" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#AA9CD4" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#665A8A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2F4F8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#BCC2CF" />
        <SolidColorBrush x:Key="StatusBrush" Color="#F1B3CB" />
        <SolidColorBrush x:Key="LineBrush" Color="#434852" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E2025" />

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1B20" Offset="0" />
            <GradientStop Color="#272431" Offset="0.58" />
            <GradientStop Color="#1D1E24" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Window">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="22" />
        </Style>

        <Style x:Key="PageHeading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="2"
                                Background="{StaticResource AccentBorderBrush}"
                                CornerRadius="6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}" Background="Transparent">
                <Border Margin="2,0" Background="#23262D" CornerRadius="6" />
                <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}" Background="Transparent">
                <Border Margin="0,2" Background="#23262D" CornerRadius="6" />
                <Track x:Name="PART_Track" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,16" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,16" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#554A74" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,6,12,6" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="2"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7667A1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#21242B" />
            <Setter Property="BorderBrush" Value="#555A66" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#2A2D34" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313541" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#554A74" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#323641" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="18">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,14" />
                                <ContentPresenter />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="DialogCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Width" Value="720" />
            <Setter Property="MaxHeight" Value="760" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="DialogTitle" TargetType="TextBlock" BasedOn="{StaticResource PageHeading}">
            <Setter Property="FontSize" Value="28" />
        </Style>

        <Style x:Key="HeaderButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="HeaderGhostButton" TargetType="Button" BasedOn="{StaticResource HeaderButton}">
            <Setter Property="Background" Value="#21242B" />
            <Setter Property="BorderBrush" Value="#555A66" />
        </Style>

        <Style x:Key="ModalCloseButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="20,0,0,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource StatusBrush}" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="BusyBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="IsIndeterminate" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#302644" />
        </Style>

        <DataTemplate DataType="{x:Type vm:LoginPageViewModel}">
            <Grid Background="{StaticResource HeroBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="72,56,40,56" VerticalAlignment="Center">
                    <Border Width="110" Height="110" CornerRadius="55" Background="#3A3450" HorizontalAlignment="Left">
                        <TextBlock Text="GM" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="GithubMin" Style="{StaticResource PageHeading}" FontSize="48" Margin="0,30,0,12" />
                    <Border Margin="0,34,0,0" Padding="24" CornerRadius="18" Background="#22242A" BorderBrush="#45495A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Что доступно" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Style="{StaticResource MutedText}" Text="Коммиты снимков состояния, ветки, merge с конфликтами, публичные и приватные репозитории, поиск по репозиториям и пользователям." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" MaxWidth="470" Margin="32,48,60,48" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="Вход" Style="{StaticResource PageHeading}" FontSize="32" Margin="0,0,0,6" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Логин или электронная почта" />
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Войти" Command="{Binding LoginCommand}" />
                            <Button Content="Регистрация" Style="{StaticResource GhostButton}" Command="{Binding OpenRegisterCommand}" />
                        </WrapPanel>

                        <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterPageViewModel}">
            <Grid Background="{StaticResource HeroBrush}">
                <Border Style="{StaticResource CardBorder}" MaxWidth="520" Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Регистрация" Style="{StaticResource PageHeading}" FontSize="32" Margin="0,0,0,6" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Имя пользователя" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Электронная почта" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Создать аккаунт" Command="{Binding RegisterCommand}" />
                            <Button Content="Назад ко входу" Style="{StaticResource GhostButton}" Command="{Binding OpenLoginCommand}" />
                        </WrapPanel>

                        <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectsPageViewModel}">
            <Grid Background="Transparent" Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20,18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Репозитории" Style="{StaticResource PageHeading}" FontSize="30" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Content="Создать" Style="{StaticResource HeaderButton}" Command="{Binding OpenCreateProjectDialogCommand}" />
                            <Button Content="Пользователи" Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenUserSearchDialogCommand}" />
                            <Button Content="Обновить" Style="{StaticResource HeaderGhostButton}" Command="{Binding RefreshCommand}" />
                            <Button Content="Выйти" Style="{StaticResource HeaderGhostButton}" Command="{Binding LogoutCommand}" Margin="0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Мои репозитории">
                        <DockPanel>
                            <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                <Button Content="Привязать папку" Style="{StaticResource GhostButton}" Command="{Binding AttachDirectoryToSelectedProjectCommand}" />
                            </WrapPanel>
                            <DataGrid ItemsSource="{Binding MyProjects}" SelectedItem="{Binding SelectedMyProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenSelectedProjectCommand}" />
                                </DataGrid.InputBindings>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="160" />
                                    <DataGridTextColumn Header="Видимость" Binding="{Binding VisibilityText}" Width="110" />
                                    <DataGridTextColumn Header="Ветки" Binding="{Binding BranchCount}" Width="70" />
                                    <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="84" />
                                    <DataGridTextColumn Header="Локальная папка" Binding="{Binding LocalStatus}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Публичные репозитории">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Button DockPanel.Dock="Right" Content="Найти" Command="{Binding SearchCommand}" />
                                <TextBox Margin="0,0,12,0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding PublicProjects}" SelectedItem="{Binding SelectedPublicProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenSelectedProjectCommand}" />
                                </DataGrid.InputBindings>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="160" />
                                    <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerUsername}" Width="130" />
                                    <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="84" />
                                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="О выбранном репозитории" Style="{StaticResource SectionTitle}" />
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,14" Text="Выберите репозиторий в одном из списков слева, чтобы быстро увидеть основную информацию." />

                            <TextBlock Style="{StaticResource MetricCaption}" Text="Название" />
                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ActiveSelection.Name}" />

                            <TextBlock Style="{StaticResource MetricCaption}" Text="Владелец" Margin="0,14,0,4" />
                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ActiveSelection.OwnerUsername}" />

                            <TextBlock Style="{StaticResource MetricCaption}" Text="Видимость" Margin="0,14,0,4" />
                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ActiveSelection.VisibilityText}" />

                            <TextBlock Style="{StaticResource MetricCaption}" Text="Локальная папка" Margin="0,14,0,4" />
                            <TextBlock Style="{StaticResource MutedText}" Text="{Binding ActiveSelection.LocalStatus}" />

                            <TextBlock Style="{StaticResource MetricCaption}" Text="Описание" Margin="0,14,0,4" />
                            <TextBlock Style="{StaticResource MutedText}" Text="{Binding ActiveSelection.Description}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectDetailsPageViewModel}">
            <Grid Background="Transparent" Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20,18">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource PageHeading}" FontSize="28" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Content="Папка" Style="{StaticResource HeaderButton}" Command="{Binding OpenDirectoryDialogCommand}" />
                            <Button Content="Ветки" Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenBranchDialogCommand}" />
                            <Button Content="Коммит" Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenCommitDialogCommand}" />
                            <Button Content="Merge" Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenMergeDialogCommand}" />
                            <Button Content="Обновить" Style="{StaticResource HeaderGhostButton}" Command="{Binding ReloadCommand}" />
                            <Button Content="Назад" Style="{StaticResource HeaderGhostButton}" Command="{Binding BackCommand}" Margin="0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.7*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                        <StackPanel>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Обзор проекта" Style="{StaticResource SectionTitle}" />
                                    <UniformGrid Columns="2" Margin="0,4,0,0">
                                        <StackPanel Margin="0,0,16,16">
                                            <TextBlock Style="{StaticResource MetricCaption}" Text="Владелец" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding OwnerUsername}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Style="{StaticResource MetricCaption}" Text="Видимость" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding VisibilityText}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,16">
                                            <TextBlock Style="{StaticResource MetricCaption}" Text="Активная ветка" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ActiveBranchName}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Style="{StaticResource MetricCaption}" Text="Коммитов / веток" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding CommitCount, StringFormat={}{0} коммитов}" />
                                            <TextBlock Style="{StaticResource MutedText}" Text="{Binding BranchCount, StringFormat={}{0} веток}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Style="{StaticResource MetricCaption}" Text="Рабочая директория" />
                                    <TextBlock Style="{StaticResource MutedText}" Text="{Binding WorkingDirectory}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Подсказка" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Style="{StaticResource MutedText}" Text="Все операции по рабочей папке, веткам, коммитам и merge открываются из кнопок в заголовке. Основная рабочая область отведена под историю и обзор проекта." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="240" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Grid.Row="0" Header="Ветки проекта">
                            <DataGrid ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ветка" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Коммитов" Binding="{Binding CommitCount}" Width="90" />
                                    <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="80" />
                                    <DataGridTextColumn Header="Создана" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="История коммитов и снапшотов">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                    <Button Content="Скачать снапшот" Command="{Binding DownloadCommitCommand}" />
                                    <Button Content="Восстановить снапшот" Style="{StaticResource GhostButton}" Command="{Binding RestoreCommitCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140" />
                                        <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*" />
                                        <DataGridTextColumn Header="Ветка" Binding="{Binding BranchName}" Width="120" />
                                        <DataGridTextColumn Header="Автор" Binding="{Binding AuthorUsername}" Width="120" />
                                        <DataGridTextColumn Header="Коммит" Binding="{Binding Id}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CreateProjectDialogViewModel}">
            <Border Style="{StaticResource DialogCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Новый репозиторий" Style="{StaticResource DialogTitle}" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                        </DockPanel>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Название" />
                        <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Описание" />
                        <TextBox Text="{Binding NewProjectDescription, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Видимость" />
                        <ComboBox ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding NewProjectVisibilityOption}" DisplayMemberPath="Text" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Рабочая директория" />
                        <TextBox Text="{Binding NewProjectDirectory}" IsReadOnly="True" />

                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Выбрать папку" Command="{Binding ChooseDirectoryCommand}" />
                            <Button Content="Создать репозиторий" Command="{Binding CreateCommand}" />
                        </WrapPanel>

                        <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:UserSearchDialogViewModel}">
            <Border Style="{StaticResource DialogCard}" Width="980">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Поиск пользователей" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                    </DockPanel>

                    <DockPanel Grid.Row="1" Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Content="Найти" Command="{Binding SearchCommand}" />
                        <TextBox Margin="0,0,12,0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Пользователи">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                    <Button Content="Показать репозитории" Command="{Binding LoadProjectsCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding LoadProjectsCommand}" />
                                    </DataGrid.InputBindings>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Пользователь" Binding="{Binding Username}" Width="*" />
                                        <DataGridTextColumn Header="Зарегистрирован" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="130" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Публичные репозитории пользователя">
                            <DockPanel>
                                <DataGrid ItemsSource="{Binding UserProjects}" SelectedItem="{Binding SelectedProject}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenProjectCommand}" />
                                    </DataGrid.InputBindings>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="160" />
                                        <DataGridTextColumn Header="Коммиты" Binding="{Binding CommitCount}" Width="84" />
                                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectDirectoryDialogViewModel}">
            <Border Style="{StaticResource DialogCard}" Width="620">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Рабочая директория" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                    </DockPanel>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Текущая папка" />
                    <TextBox Text="{Binding DirectoryPath}" IsReadOnly="True" />

                    <WrapPanel Margin="0,6,0,0">
                        <Button Content="Выбрать папку" Command="{Binding ChooseDirectoryCommand}" />
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                    </WrapPanel>

                    <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:BranchManagementDialogViewModel}">
            <Border Style="{StaticResource DialogCard}" Width="860">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Управление ветками" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Существующие ветки">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                    <Button Content="Сделать активной" Command="{Binding SwitchCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ветка" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Коммитов" Binding="{Binding CommitCount}" Width="90" />
                                        <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Новая ветка">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Имя ветки" />
                                <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Стартовый коммит" />
                                <ComboBox ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedStartCommit}" DisplayMemberPath="Message" />

                                <Button Content="Создать ветку" Command="{Binding CreateCommand}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </GroupBox>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CreateCommitDialogViewModel}">
            <Border Style="{StaticResource DialogCard}" Width="700">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Новый коммит" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                    </DockPanel>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Ветка" />
                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" DisplayMemberPath="Name" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Рабочая директория" />
                    <TextBox Text="{Binding WorkingDirectory}" IsReadOnly="True" />
                    <Button Content="Выбрать папку" Command="{Binding ChooseDirectoryCommand}" HorizontalAlignment="Left" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Сообщение коммита" />
                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" />

                    <WrapPanel Margin="0,6,0,0">
                        <Button Content="Создать коммит" Command="{Binding CreateCommand}" />
                    </WrapPanel>

                    <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MergeDialogViewModel}">
            <Border Style="{StaticResource DialogCard}" Width="660">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Слияние веток" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Закрыть" Style="{StaticResource ModalCloseButton}" Command="{Binding CloseCommand}" />
                    </DockPanel>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Исходная ветка" />
                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedSourceBranch}" DisplayMemberPath="Name" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Целевая ветка" />
                    <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedTargetBranch}" DisplayMemberPath="Name" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Сообщение merge-коммита" />
                    <TextBox Text="{Binding MergeMessage, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" />

                    <Button Content="Выполнить merge" Command="{Binding MergeCommand}" HorizontalAlignment="Left" />

                    <ProgressBar Style="{StaticResource BusyBarStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Style="{StaticResource StatusText}" Text="{Binding StatusMessage}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <ContentControl Content="{Binding CurrentPage}" />

        <Border Panel.ZIndex="10"
                Background="#AA111319"
                Visibility="{Binding HasDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Margin="34">
                <ContentControl Content="{Binding CurrentDialog}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
